# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:1b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=512

# Embeddings (downloaded on first run, cached locally)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=customer_support_docs

# Document ingestion
RAW_DATA_DIR=./data/raw
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
RETRIEVAL_TOP_K=4
SIMILARITY_THRESHOLD=0.3

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Streamlit → API
STREAMLIT_API_URL=http://localhost:8000
